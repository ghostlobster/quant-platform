# ============================================================
# .env.example — Provider Protocol Architecture ENV vars
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# ── Provider selection ────────────────────────────────────────────────────────
LLM_PROVIDER=mock               # mock | anthropic | openai | ollama
MARKET_DATA_PROVIDER=yfinance   # yfinance | alpaca | mock
BROKER_PROVIDER=paper           # paper | alpaca | ibkr | schwab
ALERT_PROVIDER=noop             # noop | slack | email
SENTIMENT_PROVIDER=vader        # vader | stocktwits | mock
EXECUTION_ALGO=market           # market | twap | vwap
TSDB_PROVIDER=sqlite            # sqlite | duckdb | timescale
FEATURE_STORE_PROVIDER=memory   # memory | redis

# ── LLM adapters ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Market data ───────────────────────────────────────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_BASE_URL=https://data.alpaca.markets

# ── Broker ────────────────────────────────────────────────────────────────────
# Alpaca — same keys as market data above
# IBKR (Interactive Brokers TWS/Gateway)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
# Schwab
SCHWAB_API_KEY=
SCHWAB_SECRET_KEY=
SCHWAB_ACCOUNT_ID=
SCHWAB_TOKEN_PATH=./schwab_token.json
# Paper trading
PAPER_STARTING_CASH=100000
MAX_DRAWDOWN_PCT=0.20

# ── Alert ─────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#alerts

EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_TO=

# ── Execution algo ────────────────────────────────────────────────────────────
TWAP_SLICE_SECONDS=60
VWAP_LOOKBACK_DAYS=5

# ── TSDB ──────────────────────────────────────────────────────────────────────
SQLITE_TSDB_PATH=quant_tsdb.db
DUCKDB_PATH=quant_tsdb.duckdb
TIMESCALE_DSN=postgresql://user:password@localhost:5432/quant

# ── Feature Store ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_FEATURE_TTL_SECONDS=86400

# ── App (existing) ────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
